{
  "name": "primes",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "clear-wasm": "rm -f -r primes-rs/pkg",
    "build-wasm": "npm run clear-wasm && RUSTFLAGS='--cfg getrandom_backend=\"wasm_js\"' wasm-pack build primes-rs --scope caiocampos",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/router": "^22.0.6",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.6",
    "@types/jasmine": "~6.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~6.3",
    "karma": "~6.4",
    "karma-chrome-launcher": "~3.2",
    "karma-coverage": "~2.2",
    "karma-jasmine": "~5.1",
    "karma-jasmine-html-reporter": "~2.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}